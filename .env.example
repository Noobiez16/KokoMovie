# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=kokomovie
POSTGRES_PASSWORD=kokomovie_dev_pass
POSTGRES_DB=kokomovie
DATABASE_URL=postgresql://kokomovie:kokomovie_dev_pass@localhost:5432/kokomovie

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── DynamoDB Local ──────────────────────────────────────────────────────────
DYNAMODB_ENDPOINT=http://127.0.0.1:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ─── Service Ports ───────────────────────────────────────────────────────────
AUTH_PORT=3001
CATALOG_PORT=3002
PLAYBACK_PORT=3003
USER_PORT=3004
RECOMMENDATION_PORT=3005

# ─── TMDB — REQUIRED for catalog to show real content ────────────────────────
# Get a free key at: https://www.themoviedb.org/settings/api (no credit card)
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
# RSA-4096 keys are auto-generated on first run → services/auth/keys/
# To regenerate: node scripts/generate-keys.mjs

# ─── Google OAuth (optional — leave blank to disable Google login) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/oauth/google/callback

# ─── S3 / CloudFront (optional — only needed for self-hosted video content) ───
CLOUDFRONT_DOMAIN=
S3_MEDIA_BUCKET=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# ─── Sentry (optional — crash reporting for production builds) ───────────────
SENTRY_DSN=
