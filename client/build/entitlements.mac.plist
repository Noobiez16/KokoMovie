<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's JavaScript JIT compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for Electron renderer process memory model -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required for loading native Node.js addons (keytar, better-sqlite3) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access for streaming and API calls -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read/write access for offline downloads directory -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Required for Widevine CDM (DRM) sandbox -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
  </dict>
</plist>
