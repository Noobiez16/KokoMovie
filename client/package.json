{
  "name": "kokomovie-client",
  "version": "1.0.2-beta",
  "description": "KokoMovie desktop streaming client — Windows, macOS, Linux",
  "author": {
    "name": "KokoMovie Inc.",
    "email": "support@kokomovie.com",
    "url": "https://kokomovie.com"
  },
  "homepage": "https://kokomovie.com",
  "private": true,
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json -w\" \"nodemon --watch dist-electron --delay 3 --exec electron --no-sandbox .\"",
    "electron:build": "npm run build && electron-builder",
    "rebuild:native": "electron-rebuild --version 31.7.7",
    "dist:linux": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.linux.yml",
    "dist:win": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.win.yml",
    "dist:mac": "npm run build && npm run rebuild:native && electron-builder --config electron-builder.mac.yml",
    "dist:all": "npm run dist:linux && npm run dist:win",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@sentry/electron": "^5.0.0",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-query-devtools": "^5.56.0",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.3.0",
    "hls.js": "^1.5.0",
    "keytar": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@kokomovie/shared": "*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "app-builder-bin": "^5.0.0-alpha.10",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "31.7.7",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^2.1.0"
  }
}
